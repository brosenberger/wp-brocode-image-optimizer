parameters:
    level: 6
    paths:
        - brocode-image-optimizer.php
    excludePaths:
        - vendor
        - tests
        - node_modules(?)
    ignoreErrors:
        # WP_CLI and WP_CLI_Command have no PHPStan stubs in phpstan-wordpress;
        # usage is already guarded by class_exists() at runtime.
        - '#on an unknown class WP_CLI#'
        - '#extends unknown class WP_CLI_Command#'
